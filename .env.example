# Copy this file to .env and fill in values. The .env file is gitignored.
#
# Minimum to start the stack (Step 1): no keys required, just `cp .env.example .env`.
# Keys become required from Step 4 onwards (embedding + summary need an LLM).

# === LLM provider (answering — Steps 7+) ===
LLM_PROVIDER=openai            # openai | ollama
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# === Local LLM via Ollama (alternate path, `docker compose --profile local-llm up`) ===
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# === Embedding provider (indexing — Steps 4+) ===
EMBED_PROVIDER=openai          # openai | sbert
EMBED_MODEL=text-embedding-3-small

# === Summary generation (indexing-time LLM — Steps 4+) ===
SUMMARY_PROVIDER=openai        # openai | ollama
SUMMARY_MODEL=gpt-4o-mini

# === Judge model (eval — Step 10) ===
JUDGE_PROVIDER=openai
JUDGE_MODEL=gpt-4o

# === Reranker (local cross-encoder — Step 6+) ===
RERANKER_MODEL=BAAI/bge-reranker-base

# === Weaviate connection ===
WEAVIATE_URL=http://weaviate:8080
WEAVIATE_GRPC_PORT=50051

# === Repo ===
REPO_NAME=flask
REPO_PATH=/app/repos/flask

# === Server ===
LOG_LEVEL=info
